# Ignore swap files generated during editing
*.swp
*.swo

# Ignore undo history (if you have 'undofile' enabled)
undo/
*.un~

# Ignore Neovim's automated state/shada files
# (This tracks marks, registers, and search history)
shada/
*.log

# Ignore local session files
Session.vim

# Optional: Ignore tags generated by ctags/gutags
tags
